generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DiscountType {
  percent
  fixed
}

enum PaymentStatus {
  pending
  processing
  success
  failed
  refunded
  partially_refunded
}

enum RefundStatus {
  pending
  processing
  failed
  success
}

enum Region {
  NORTH // Miền Bắc
  CENTRAL // Miền Trung
  SOUTH // Miền Nam
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  ALL
}

model Role {
  id          Int      @id @default(autoincrement())
  name_role   String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts             Account[]
  rolePermissions      RolePermission[]
  rolePermissionGroups RolePermissionGroup[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  label       String
  description String?
  groupId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group           PermissionGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rolePermissions RolePermission[]

  @@index([groupId])
}

model RolePermission {
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permissionId])
}

model Account {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String
  avatar    String   @default("")
  roleId    Int
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role            Role      @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewsApproved Review[]  @relation("Reviewer")
  shopResponder   Review[]  @relation("ShopResponder")
  payments        Payment[]
  refunds         Refund[]
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String   @default("")
  googleId       String?  @unique
  phone          String?
  address        String?
  points         Int      @default(0)
  avatar         String?
  is_active      Boolean  @default(true)
  is_verifyEmail Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pointHistory     PointHistory[]
  cart             Cart?
  orders           Order[]
  reviews          Review[]
  userBankAccounts UserBankAccount[]
  productViews     ProductView[]
}

model PointHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  points      Int
  type        String
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Gender {
  id          Int      @id @default(autoincrement())
  name_gender String   @unique
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories Category[]
}

model Category {
  id             Int      @id @default(autoincrement())
  name_category  String   @unique
  slug           String   @unique
  description    String?
  image_category String
  genderId       Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gender     Gender?     @relation(fields: [genderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  products   Product[]
  sizeGuides SizeGuide[]
}

model ProductStatus {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  hex         String
  description String?

  products Product[]
}

model Sale {
  id             Int          @id @default(autoincrement())
  name_sale      String
  description    String?
  discount_type  DiscountType @default(percent)
  discount_value Decimal      @default("0") @db.Decimal(12, 2)
  start_date     DateTime?
  end_date       DateTime?
  is_active      Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products Product[]
}

model Product {
  id           Int      @id @default(autoincrement())
  name_product String
  description  String?  @db.LongText
  season       Season
  slug         String   @unique
  price        Decimal  @db.Decimal(12, 2)
  image_url    String?  @db.LongText
  sold         Int      @default(0)
  categoryId   Int?
  saleId       Int?
  statusId     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sale     Sale?          @relation(fields: [saleId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status   ProductStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  variants     ProductVariant[]
  reviews      Review[]
  productViews ProductView[]
}

model Color {
  id         Int     @id @default(autoincrement())
  name_color String
  hex        String?

  variants ProductVariant[]

  @@unique([name_color, hex])
}

model Size {
  id        Int    @id @default(autoincrement())
  name_size String @unique
  Symbol    String @unique

  variants   ProductVariant[]
  sizeGuides SizeGuide[]
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int
  colorId   Int?
  sizeId    Int?
  stock     Int      @default(0)
  sold      Int      @default(0)
  image_url String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  color   Color?  @relation(fields: [colorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  size    Size?   @relation(fields: [sizeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, colorId, sizeId])
  @@index([productId])
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items CartItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  variantId Int
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([cartId])
  @@index([variantId])
}

model Voucher {
  id              Int          @id @default(autoincrement())
  code            String       @unique
  description     String?
  discount_type   DiscountType @default(percent)
  discount_value  Decimal      @default("0") @db.Decimal(12, 2)
  min_order_value Decimal      @db.Decimal(12, 2)
  start_date      DateTime?
  end_date        DateTime?
  usage_limit     Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  is_active       Boolean      @default(true)

  orders Order[]
}

model OrderStatus {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  sort_order    Int?
  code          String   @unique
  hex           String
  description   String
  is_final      Boolean  @default(false)
  is_cancelable Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]
}

model PointRule {
  id              Int          @id @default(autoincrement())
  required_points Int
  discount_type   DiscountType
  discount_value  Decimal      @db.Decimal(12, 2)
  is_active       Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Order {
  id        Int  @id @default(autoincrement())
  userId    Int?
  voucherId Int?
  statusId  Int

  cancel_reason String?   @db.LongText
  cancelledAt   DateTime?

  receiver_name    String?
  receiver_email   String?
  receiver_phone   String?
  receiver_address String?
  receiver_note    String?

  total_price           Decimal? @db.Decimal(12, 2)
  shipping_fee          Decimal? @default("0") @db.Decimal(12, 2)
  used_points           Int      @default(0)
  earned_points         Int      @default(0)
  point_discount_amount Decimal? @default("0") @db.Decimal(12, 2)

  payment_method Int

  estimated_delivery_at DateTime?
  delivered_at          DateTime?
  shipped_at            DateTime?

  expires_at DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  voucher       Voucher?      @relation(fields: [voucherId], references: [id])
  status        OrderStatus   @relation(fields: [statusId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [payment_method], references: [id])

  items   OrderItem[]
  payment Payment[]
}

model Return {
  id          Int @id @default(autoincrement())
  orderItemId Int @unique
  userId      Int

  reason   String  @db.LongText
  imageUrl String? @db.LongText

  status ReturnStatus @default(PENDING)

  adminNote String? @db.LongText

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem @relation(fields: [orderItemId], references: [id])
  refunds    Refund[]
}

model Refund {
  id Int @id @default(autoincrement())

  orderItemId Int
  paymentId   Int

  amount Decimal @db.Decimal(12, 2)
  reason String  @db.LongText

  status                RefundStatus @default(pending)
  transaction_reference String?      @unique
  returnId              Int

  refundProofImage String?

  processedByAdminId Int?
  refundedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orderItem        OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  payment          Payment   @relation(fields: [paymentId], references: [id])
  processedByAdmin Account?  @relation(fields: [processedByAdminId], references: [id], onDelete: SetNull)
  return           Return    @relation(fields: [returnId], references: [id])

  @@index([orderItemId])
  @@index([paymentId])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  variantId Int
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviews Review?
  returns Return?
  refunds Refund[]

  @@index([orderId])
  @@index([variantId])
}

model Review {
  id          Int @id @default(autoincrement())
  userId      Int
  orderItemId Int @unique

  rating  Int
  comment String?
  images  String? @db.LongText

  status      ReviewStatus @default(PENDING)
  approved_at DateTime?
  approved_by Int?
  productId   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopReply     String?   @db.LongText
  shopRepliedAt DateTime?
  shopRepliedBy Int?

  shopResponder Account? @relation("ShopResponder", fields: [shopRepliedBy], references: [id], onDelete: SetNull)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer  Account?   @relation("Reviewer", fields: [approved_by], references: [id], onDelete: SetNull)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([productId])
}

model PaymentMethod {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders   Order[]
  payments Payment[]
}

model Payment {
  id                    Int           @id @default(autoincrement())
  orderId               Int
  amount                Decimal       @db.Decimal(12, 2)
  status                PaymentStatus @default(pending)
  payment_method        Int
  transaction_reference String?       @unique
  payment_date          DateTime?
  collectedByAdminId    Int?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  received_at           DateTime?

  collectedByAdmin Account?      @relation(fields: [collectedByAdminId], references: [id])
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  method           PaymentMethod @relation(fields: [payment_method], references: [id], onDelete: Restrict, onUpdate: Cascade)
  refunds          Refund[]
}

model DailyReport {
  id                  Int      @id @default(autoincrement())
  report_date         DateTime @unique
  total_orders        Int      @default(0)
  total_revenue       Decimal  @default("0") @db.Decimal(18, 2)
  new_users           Int      @default(0)
  total_products_sold Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PermissionGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique // product, order, user, report...
  label       String // Quản lý sản phẩm
  description String?
  sort_order  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions          Permission[]
  rolePermissionGroups RolePermissionGroup[]
}

model RolePermissionGroup {
  roleId            Int
  permissionGroupId Int
  is_enabled        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  role            Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionGroup PermissionGroup @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionGroupId])
}

model UserBankAccount {
  id          Int      @id @default(autoincrement())
  userId      Int
  bankCode    String // VCB, TCB, MB, ACB... 
  bankName    String // Tên ngân hàng 
  accountNo   String // Số tài khoản 
  accountName String // Tên chủ tài khoản 
  is_primary  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, is_primary])
  @@index([userId])
}

model SizeGuide {
  id Int @id @default(autoincrement())

  sizeId     Int
  categoryId Int

  size     Size     @relation(fields: [sizeId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  measurements SizeMeasurement[]
}

model ProductView {
  id Int @id @default(autoincrement())

  userId    Int
  productId Int

  viewedAt  DateTime @updatedAt
  viewCount Int      @default(1)

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model MeasurementType {
  id   Int    @id @default(autoincrement())
  name String @unique
  unit String

  measurements SizeMeasurement[]
}

model SizeMeasurement {
  id Int @id @default(autoincrement())

  sizeGuideId       Int
  measurementTypeId Int

  min Int
  max Int

  sizeGuide       SizeGuide       @relation(fields: [sizeGuideId], references: [id])
  measurementType MeasurementType @relation(fields: [measurementTypeId], references: [id])
}
